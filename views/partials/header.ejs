<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book Notes</title>

  <!-- Bootstrap CSS -->
  <link
    rel="stylesheet"
    href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css"
    integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T"
    crossorigin="anonymous"
  />

  <!-- Your Custom Styles -->
  <link rel="stylesheet" href="/styles.css" />

  </head>
  <body>
  <main>
   <!-- Bootstrap Navigation Bar -->
    <nav class="navbar navbar-expand-lg custom-navbar">
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav"
        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link text-black <%= activePage === 'home' ? 'active' : '' %>" href="/">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-black <%= activePage === 'addBook' ? 'active' : '' %>" href="/addBook">Add Book</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-black <%= activePage === 'addUser' ? 'active' : '' %>" href="/addUser">Add New User</a>
                </li>
            </ul>

    <!-- Search form aligned right -->
            <form class="form-inline my-2 my-lg-0 flex-nowrap" action="/searchUser" method="GET">
    <input
        class="form-control mr-sm-2"
        type="text"
        name="first_name"
        placeholder="First Name"
        aria-label="First Name"
        required
    />
    <input
        class="form-control mr-sm-2"
        type="text"
        name="surname"
        placeholder="Surname"
        aria-label="Surname"
        required
    />
    <button class="btn custom-search-btn my-2 my-sm-0" type="submit">Search</button>
</form>
        </div>
    </nav>