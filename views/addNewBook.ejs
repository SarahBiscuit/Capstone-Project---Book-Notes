<div class="container headerBoxes">
<div class="container mainHeader">
<%# Main header %>
</br>
    <div class="container bookNotesHeader col-lg-6 col-md-8 col-12 mb-4">
        <h1><span><b>Add New Book</b></span></h1>
    </div>

<%# Sub Header %>
    <div class="container bookNotesSubHeader col-lg-10 col-md-10 col-12 mb-4">
        <h3>
            <p><span><b>Use this form to add a new book recommendation.</b></span></p>
            <p><span><b>Happy reading!</b></span></p>
        </h3>
    </div>
