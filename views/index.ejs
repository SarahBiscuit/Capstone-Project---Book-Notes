<%- include("partials/header.ejs") %>

</br>
</br>

<div class="container headerBoxes" id="headerBoxesHomepage">
<% /* Main header */ %>
  <div class="container mainHeader">
  </br>
    <div class="container bookNotesHeader col-lg-6 col-md-8 col-12 mb-4">
        <h1><span><b>Books We Recommend</b></span></h1>
    </div>
<% /* Sub Header */ %>
    <div class="container bookNotesSubHeader col-lg-10 col-md-10 col-12 mb-4">
        <h3>
            <p><span><b>Select a user using the 'select user' search box above, and explore their favourite reads.</b></span></p>
            <p><span><b>You can also add yourself as a new user, and add your favourite reads.</b></span></p>
            <p><span><b>Because there is nothing better than a good book.</b></span></p>
        </h3>
    </div>
  </div>

</br>
</br>

<div class="headerBoxes">
<% /* Header bar with user name in */ %>
    <div class="container bookNotesHeader col-lg-6 col-md-8 col-12 mb-4">
        <h2>
            <%= (first_name && surname) ? `User Name - ${first_name} ${surname}` : 'Select a user to view their book recommendations' %>
        </h2>
    </div>

</div>

<% /* Error Message Display */ %>
<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="alert alert-danger" role="alert">
    <%= errorMessage %>
  </div>
<% } %>

<% /* Sort By Rating */ %>
           <form action="/sortByRating" method="GET" style="display:inline;">
            <input type="hidden" name="user_id" value="<%= user_id %>">
            <button type="submit" class="btn btn-danger">Sort By Rating</button>
           </form>

<% /* Sort By Year Read */ %>
           <form action="/sortByYear" method="GET" style="display:inline;">
            <input type="hidden" name="user_id" value="<%= user_id %>">
            <button type="submit" class="btn btn-danger">Sort By Year the User Read it in</button>
           </form>

<% /* For each function to generate bootstrap cards for each book.  Want to rewrite it as jquery. */ %>
<div class="container mt-4">
  <div class="row">
    
<% if (books && books.length > 0) { %>
  <% books.forEach(function(book) { %>
    <div class="col-lg-4 col-md-6 col-12 mb-4">
      <div class="card h-100">
        <img src="<%= book.img || '' %>" class="card-img-top" alt="Book image">
        <div class="card-body">
          <h5 class="card-title"><b>Title:</b> <%= book.title || '' %></h5>
          <p class="card-text"><b>Author:</b> <%= book.author || '' %></p>
          <p class="card-text"><b>User's Rating Out of 10:</b> <%= book.my_rating || '' %></p>
          <p class="card-text"><b>Year User Read It:</b> <%= book.year_i_read_it || '' %></p>
          <p class="card-text"><b>User's Notes:</b> <%= book.guidance_notes || '' %></p>
          
<% /* Edit Form in Bootstrap modal */ %>
      <% /* Edit Button */ %>
<button type="button" class="btn btn-warning" data-toggle="modal" data-target="#editModal_<%= book.book_id %>">
  Edit 
</button>
<% /* Modal */ %>
<div class="modal fade" id="editModal_<%= book.book_id %>" tabindex="-1" role="dialog" aria-labelledby="editModal_<%= book.book_id %>" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <form method="POST" action="/edit">
        <div class="modal-header">
          <h5 class="modal-title" id="editModalLabel"><b>Edit Book</b></h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <% /* Form fields */ %>
          <input type="hidden" name="book_id" value="<%= book.book_id %>" />

          <div class="mb-3">
            <label for="title_<%= book.book_id %>" class="form-label">Title</label>
  <input type="text" name="title" id="title_<%= book.book_id %>" class="form-control" value="<%= book.title %>" />
          </div>

          <div class="mb-3">
            <label for="author_<%= book.book_id %>" class="form-label">Author</label>
            <input type="text" name="author" id="author_<%= book.book_id %>" class="form-control" value="<%= book.author %>" />
          </div>

          <div class="mb-3">
            <label for="year_i_read_it_<%= book.book_id %>" class="form-label">Year You Read This Book</label>
            <input type="number" name="year_i_read_it" id="year_i_read_it_<%= book.book_id %>" class="form-control" value="<%= book.year_i_read_it %>" />
          </div>

          <div class="mb-3">
            <label for="my_rating_<%= book.book_id %>" class="form-label">Rating</label>
            <input type="number" name="my_rating" id="my_rating_<%= book.book_id %>" class="form-control" value="<%= book.my_rating %>" min="1" max="10" />
          </div>

          <div class="mb-3">
            <label for="guidance_notes_<%= book.book_id %>" class="form-label">Your Book Review</label>
            <textarea type="text" name="guidance_notes" id="guidance_notes_<%= book.book_id %>" class="form-control"><%= book.guidance_notes || '' %></textarea>
          </div>

          <div class="mb-3">
            <input type="hidden" name="user_id" value="<%= book.user_id %>" />
            <input type="hidden" name="first_name" value="<%= book.first_name %>" />
            <input type="hidden" name="surname" value="<%= book.surname %>" />
          </div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-warning" data-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Save changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<% /* Delete Form */ %>
          <form action="/books/<%= book.book_id %>?_method=DELETE" method="POST" style="display:inline;">
            <input type="hidden" name="first_name" value="<%= book.first_name %>"> 
            <input type="hidden" name="surname" value="<%= book.surname %>">
            <input type="hidden" name="user_id" value="<%= book.user_id %>" />
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this book?');">Delete</button>
          </form>

        </div>
      </div>
    </div>
  <% }) %>
<% } else { %>
  <div class="col-12">
    <div class="alert alert-info" role="alert">
      No books found for this user. Please add some books.
    </div>
  </div>
<% } %>
</div>

<%- include("partials/footer.ejs") %>