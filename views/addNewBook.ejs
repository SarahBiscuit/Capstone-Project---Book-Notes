<%- include("partials/header.ejs") %>

<div class="container headerBoxes">
<%# Main header %>
    <div class="container bookNotesHeader">
        <h1><span><b>Add New Book</b></span></h1>
    </div>

<%# Sub Header %>
    <div class="container bookNotesSubHeader">
        <h3>
            <p><span><b>Use this form to add a new book recommendation.</b></span></p>
            <p><span><b>Happy reading!</b></span></p>
        </h3>
    </div>
</div>

<div class="container-fluid addNewUserForm">
    <%# Want to add a form in to add a new book, and have an image floating to the right of the form (to change to below it on smaller screens) %>
    <div class="row">
        <div class="col-md-6 col-sm-12">
            <form action="/addBook" method="POST">
                <div class="form-group mb-3">
                    <label for="userForename">User Forename: </label>
                    <input type="text" class="form-control" id="forename" name="forename" required>
                    <label for="userSurname"> User Surname: </label>
                    <input type="text" class="form-control" id="surname" name="surname" required>
                    <label for="first_name">Author: </label>
                    <input type="text" class="form-control" id="author" name="author" required>
                    <label for="surname">title: </label>
                    <input type="text" class="form-control" id="title" name="title" required>
                    <label for="yearRead">Year You Read It: </label>
                    <input type="number" class="form-control" id="yearRead" name="yearRead" required>
                    <label for="guidanceNotes">Your review notes on this book: </label>
                    <textarea name="guidance_notes" id="guidance_notes" class="form-control" type="text"></textarea>
                </div>

                <!-- Rating Field -->
                <div class="form-group mb-3">
                    <label for="rating">How would you rate this book? (1 = worst, 10 = best)</label>
                    <select class="form-control" id="rating" name="rating" required>
                        <option value="">Select a rating</option>
                        <% for (var i = 1; i <= 10; i++) { %>
                            <option value="<%= i %>"><%= i %></option>
                        <% } %>
                    </select>
                </div>

            <!-- Submit Button -->
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>

        <!-- Book Image (floats right on larger screens, stacks on smaller) -->
        <div class="col-md-6 col-sm-12 text-center mt-3">
            <img src="#" alt="Image of a book" class="img-fluid" style="max-width: 300px; max-height: 300px;" />
        </div>
    </div>
</div>

<%- include("partials/footer.ejs") %>