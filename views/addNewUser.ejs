<div class="container-fluid addNewUserForm col-lg-6 col-md-8 col-12 mb-4">
    <%# Want to add a form in to add a new user, and have an image floating to the right of the form (to change to below it on smaller screens) %>
    <div class="row">
        <div>
            <form action="/addUser" method="POST">
                <div class="form-group mb-3">
                    <div class="row">
                     <div class="col-12">
                        <label for="first_name">Forename:</label>
                        <input type="text" class="form-control" id="first_name" name="first_name" required>
                    </div>
                    <div class="col-12 mt-3">
                        <label for="surname">Surname:</label>
                        <input type="text" class="form-control" id="surname" name="surname" required>
                    </div>
        </div>
    </div>
                
            <!-- Submit Button -->
                <button type="submit" class="btn btn-danger">Submit</button>
            </form>
        </div>

    </div>
</div>

