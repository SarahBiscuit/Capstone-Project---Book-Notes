    <div class="container bookNotesHeader col-lg-6 col-md-8 col-12 mb-4">
        <h1><span><b>Add New User</b></span></h1>
    </div>
<%# Sub Header %>
    <div class="container bookNotesSubHeader col-lg-10 col-md-10 col-12 mb-4">
        <h3>
            <p><span><b>Use the form below to add yourself as a new user.</b></span></p>
            <p><span><b>And then start recommending books yourself.</b></span></p>
        </h3>
