<%- include("partials/header.ejs") %>

<div class="container headerBoxes">
<%# Main header %>
    <div class="container bookNotesHeader">
        <h1><span><b>Books We Recommend</b></span></h1>
    </div>
<%# Sub Header %>
    <div class="container bookNotesSubHeader">
        <h3>
            <p><span><b>Select a user using the 'select user' search box above, and explore their favourite reads.</b></span></p>
            <p><span><b>You can also add yourself as a new user, and add your favourite reads.</b></span></p>
            <p><span><b>Because there is nothing better than a good book.</b></span></p>
        </h3>
    </div>
</div>

<div class="headerBoxes">
<%# Header bar with user name in %>
    <div class="container userheader">
        <h2>
            <span><b><%= userName ? `User Name - ${forename} ${surname}`: `Select a user to view their book recommendations` %></b></span>
        </h2>
    </div>

<%# Sub Header %>
    <div class="container bookNotesSubHeader">
        <h3>
            <span><b>Please see my book recommendations below</b></span>
        </h3>
    </div>
</div>

<%# For each function to generate bootstrap cards for each book.  Want to rewrite it as jquery.  %>
<div class="container mt-4">
  <div class="row">
    
<% if (books && books.length > 0) { %>
  <% books.forEach(function(book) { %>
    <div class="col-lg-4 col-md-6 col-12 mb-4">
      <div class="card h-100">
        <img src="<%= book.img || '' %>" class="card-img-top" alt="Book image">
        <div class="card-body">
          <h5 class="card-title"><%= book.title || '' %></h5>
          <p class="card-text"><%= book.author || '' %></p>
          <p class="card-text"><%= book.rating || '' %></p>
          <p class="card-text"><%= book.yearRead || '' %></p>
          <p class="card-text"><%= book.guidanceNotes || '' %></p>
          
        <!-- Edit Form in Bootstrap modal -->
      <!-- Edit Button -->
<button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#editModal">
  Edit 
</button>
<!-- Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <form method="POST" action="/edit">
        <div class="modal-header">
          <h5 class="modal-title" id="editModalLabel">Edit Book</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <!-- Form fields -->
          <input type="hidden" name="book_id" value="<%= book.book_id %>" />

          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="title" id="title" class="form-control" value="<%= book.title %>" />
          </div>

          <div class="mb-3">
            <label for="author" class="form-label">Author</label>
            <input type="text" name="author" id="author" class="form-control" value="<%= book.author %>" />
          </div>

          <div class="mb-3">
            <label for="year_read" class="form-label">Year You Read This Book</label>
            <input type="number" name="year_read" id="year_read" class="form-control" value="<%= book.year_read %>" />
          </div>

          <div class="mb-3">
            <label for="rating" class="form-label">Rating</label>
            <input type="number" name="rating" id="rating" class="form-control" value="<%= book.rating %>" min="1" max="10" />
          </div>

          <div class="mb-3">
            <label for="guidance_notes" class="form-label">Your Book Review</label>
            <textarea name="guidance_notes" id="guidance_notes" class="form-control"><%= book.guidance_notes || '' %></textarea>
          </div>

          <div class="mb-3">
            <label for="forename" class="form-label">User Forename</label>
            <textarea name="forename" id="forename" class="form-control"><%= book.forename || '' required%></textarea>
          </div>

          <div class="mb-3">
            <label for="surname" class="form-label">User Forename</label>
            <textarea name="surname" id="surname" class="form-control"><%= book.surname || '' required%></textarea>
          </div>

        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save changes</button>
        </div>
      </form>
    </div>
  </div>
</div>
        

          <!-- Delete Form -->
          <form action="/books/<%= book.book_id %>?_method=DELETE" method="POST" style="display:inline;">
            <input type="hidden" name="forename" placeholder="user forename" value="<%= forename %>"> 
            <input type="hidden" name="surname" placeholder="user surname" value="<%= surname %>">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this book?');">Delete</button>
          </form>

          <!-- Sort By Rating -->
           <form action="/sortByRating" method="GET" style="display:inline;">
            <input type="hidden" name="userId" value="<%= userId %>">"
            <button type="submit" class="btn btn-primary">Sort By Rating</button>
           </form>

           <!-- Sort By Year Read -->
           <form action="/sortYearRead" method="GET" style="display:inline;">
            <input type="hidden" name="userId" value="<%= userId %>">"
            <button type="submit" class="btn btn-primary">Sort By Year the User Read it in</button>
           </form>

        </div>
      </div>
    </div>
  <% }) %>
<% } else { %>
  <div class="col-12">
    <div class="alert alert-info" role="alert">
      No books found for this user. Please add some books.
    </div>
  </div>
<% } %>
</div>

<%- include("partials/footer.ejs") %>