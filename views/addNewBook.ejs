<div class="container-fluid addNewBookForm col-lg-6 col-md-8 col-12 mb-4">
    <%# Want to add a form in to add a new book, and have an image floating to the right of the form (to change to below it on smaller screens) %>
    <div class="row">
        <div>
            <form action="/addBook" method="POST">
                <div class="form-group mb-3">
                    <label for="userFirstName">User First Name: </label>
                    <input type="text" class="form-control" id="first_name" name="first_name" required>
                    
                    <label for="userSurname"> User Surname: </label>
                    <input type="text" class="form-control" id="surname" name="surname" required>
                    
                    <label for="author">Author: </label>
                    <input type="text" class="form-control" id="author" name="author" required>
                    
                    <label for="title">Title: </label>
                    <input type="text" class="form-control" id="title" name="title" required>
                    
                    <label for="year_i_read_it">Year You Read It: </label>
                    <input type="number" class="form-control" id="year_i_read_it" name="year_i_read_it" required>
                    
                    <label for="guidance_notes">Your review notes on this book: </label>
                    <textarea name="guidance_notes" id="guidance_notes" class="form-control" type="text"></textarea>
                </div>

                <!-- Rating Field -->
                <div class="form-group mb-3">
                    <label for="my_rating">How would you rate this book? (1 = worst, 10 = best)</label>
                    <select class="form-control" id="my_rating" name="my_rating" required>
                        <option value="">Select a rating</option>
                        <% for (var i = 1; i <= 10; i++) { %>
                            <option value="<%= i %>"><%= i %></option>
                        <% } %>
                    </select>
                </div>

            <!-- Submit Button -->
                <button type="submit" class="btn btn-danger">Submit</button>
            </form>
        </div>

    </div>
</div>

